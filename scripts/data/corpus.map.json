{
    "root": "~/Corpus",
    "outputs": {
        ".*Pokemon": [
            "species.data.json",
            "species.names.map.json"
        ],
        ".*Abilities": [
            "abilities.data.json",
            "ability.names.map.json"
        ],
        ".*Items": [
            "items.data.json",
            "item.names.map.json"
        ],
        ".*Moves": [
            "moves.data.json",
            "move.names.map.json"
        ]
    },
    "rules": {
        "name": {
            "isKey": true,
            "hasPrefix": true,
            "hasReplace": {
                "’": "'"
            },
            "toStrip": true
        },
        "description": {
            "hasReplace": {
                "\\n": "",
                "\n": "",
                "’": "'"
            },
            "toStrip": true,
            "keepShortest": true
        },
        "category": {
            "hasReplace": {
                "Pokémon ": "",
                "’": "'"
            },
            "toStrip": true
        }
    },
    "schema": {
        "name": {
            "SwShPokemon": {
                "en": "SwordShield/en_common.txt",
                "fr": "SwordShield/fr_common.txt",
                "beg": 13346,
                "end": 14243,
                "prefix": "SPECIES_"
            },
            "SwShAbilities": {
                "en": "SwordShield/en_common.txt",
                "fr": "SwordShield/fr_common.txt",
                "beg": 8699,
