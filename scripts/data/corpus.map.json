                "beg": 15327,
                "end": 16152,
                "prefix": "MOVE_"
            },
            "SwShGMaxMoves": {
                "en": "SwordShield/en_common.txt",
                "fr": "SwordShield/fr_common.txt",
                "beg": 18652,
                "end": 18684,
                "prefix": "MOVE_"
            }
        },
        "description": {
