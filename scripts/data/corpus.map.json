                "prefix": "ABILITY_"
            },
            "SwShItems": {
                "en": "SwordShield/en_common.txt",
                "fr": "SwordShield/fr_common.txt",
                "beg": 11712,
                "end": 13318,
                "prefix": "ITEM_"
            },
            "SwShMoves": {
